aws_region = "ap-southeast-1"

name_prefix = "mem9-node-prod"

vpc_id = "vpc-xxxxxxxxxxxxxxxxx"

public_subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",
  "subnet-yyyyyyyyyyyyyyyyy"
]

private_subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",
  "subnet-yyyyyyyyyyyyyyyyy"
]

database_subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",
  "subnet-yyyyyyyyyyyyyyyyy",
  "subnet-zzzzzzzzzzzzzzzzz"
]

database_name     = "mem9_node_prod_db"
database_username = "mem9node"
database_password = "replace-with-strong-db-password"

app_pepper                = "replace-with-32-plus-char-random-secret"
go_internal_shared_secret = "replace-with-strong-internal-shared-secret"
qwen_api_key              = "replace-with-qwen-api-key"

analysis_payload_bucket_name = "mem9-apse1-payloads-example"
payload_retention_days       = 7

mem9_source_api_base_url = "http://internal-mem9-service/v1alpha2/mem9s"
qwen_api_base_url        = "https://dashscope.aliyuncs.com/compatible-mode/v1"
qwen_model               = "qwen3.5-pro"
