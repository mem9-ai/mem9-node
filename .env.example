NODE_ENV=development
PORT=3000
WORKER_HEALTH_PORT=3001
DATABASE_URL=mysql://mem9:mem9@127.0.0.1:3306/mem9
REDIS_URL=redis://127.0.0.1:6379
APP_PEPPER=replace-with-32-char-random-secret
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://127.0.0.1:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_FORCE_PATH_STYLE=true
S3_BUCKET_ANALYSIS_PAYLOADS=mem9-analysis-payloads
SQS_ANALYSIS_BATCH_QUEUE_URL=http://127.0.0.1:4566/000000000000/analysis-batch
SQS_ANALYSIS_BATCH_DLQ_URL=http://127.0.0.1:4566/000000000000/analysis-batch-dlq
SQS_ANALYSIS_LLM_QUEUE_URL=http://127.0.0.1:4566/000000000000/analysis-llm
SQS_ANALYSIS_LLM_DLQ_URL=http://127.0.0.1:4566/000000000000/analysis-llm-dlq
MEM9_SOURCE_API_BASE_URL=http://127.0.0.1:8080/v1alpha2/mem9s
MEM9_SOURCE_PAGE_SIZE=200
MEM9_SOURCE_REQUEST_TIMEOUT_MS=10000
MEM9_SOURCE_FETCH_RETRIES=2
MEM9_SOURCE_FETCH_RETRY_BASE_MS=250
MEM9_SOURCE_DELETE_CONCURRENCY=4
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=replace-with-your-qwen-model
QWEN_REQUEST_TIMEOUT_MS=120000
DEEP_ANALYSIS_CHUNK_CONCURRENCY=5
JOB_RESULT_TTL_SECONDS=86400
PAYLOAD_RETENTION_DAYS=7
DEFAULT_BATCH_SIZE=100
MAX_BATCH_MEMORIES=100
MAX_BATCH_BYTES=524288
MAX_MEMORIES_PER_REQUEST=100
GO_VERIFY_MODE=noop
GO_VERIFY_BASE_URL=http://127.0.0.1:8080
GO_INTERNAL_SHARED_SECRET=replace-me
LOG_LEVEL=info
PIPELINE_VERSION=v1
TAXONOMY_VERSION=v3
SQS_WAIT_TIME_SECONDS=10
SQS_VISIBILITY_TIMEOUT_SECONDS=30
SQS_VISIBILITY_HEARTBEAT_SECONDS=10
