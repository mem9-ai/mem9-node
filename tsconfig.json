{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "sourceMap": true,
    "inlineSources": true,

    // Set `sourceRoot` to  "/" to strip the build path prefix
    // from generated source code references.
    // This improves issue grouping in Sentry.
    "sourceRoot": "/"
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts",
    "prisma/**/*.ts",
    "scripts/**/*.ts",
    "jest.config.ts"
  ]
}
