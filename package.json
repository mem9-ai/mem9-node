{
  "name": "mem9-node",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build && pnpm sentry:sourcemaps",
    "dev": "concurrently \"pnpm --filter @mem9/contracts build:watch\" \"pnpm --filter @mem9/config build:watch\" \"pnpm --filter @mem9/shared build:watch\" \"pnpm --filter @mem9/api dev\" \"pnpm --filter @mem9/worker dev\"",
    "lint": "pnpm -r --workspace-concurrency=1 lint",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "test": "jest --runInBand",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "test:watch": "jest --watch",
    "deep-analysis:fingerprint": "node scripts/derive-api-key-fingerprint.mjs",
    "taxonomy:v3:generate": "node scripts/generate-taxonomy-v3.mjs",
    "taxonomy:v3:check": "node scripts/check-taxonomy-v3.mjs",
    "taxonomy:v3:coverage": "node scripts/analyze-taxonomy-v3-coverage.mjs",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prepare": "prisma generate",
    "updateSentry": "npx @sentry/wizard@latest -i sourcemaps --saas --org pingcap2 --project mem9-node",
    "sentry:sourcemaps": "node scripts/sentry-sourcemaps.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/client-sqs": "^3.1008.0",
    "@aws-sdk/lib-storage": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/testing": "^11.1.16",
    "@prisma/client": "^6.10.1",
    "@sentry/cli": "^2.58.5",
    "@sentry/nestjs": "^10.46.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.0",
    "nestjs-pino": "^4.6.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prisma": "^6.10.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
